# PostgreSQL Configuration
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=study_room
# Set to true if your Postgres instance requires SSL (e.g. cloud providers)
PG_SSL=false

# Server Configuration
PORT=4000
LOG_LEVEL=info
APP_PUBLIC_URL=http://localhost:4000
WEB_APP_URL=http://localhost:5173

# JWT Configuration
JWT_SECRET=replace-with-strong-random-secret-key
JWT_EXPIRES_IN=8h
STUDENT_JWT_EXPIRES_IN=30d

# Razorpay (test credentials for the student mobile app)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Seed Admin (created/refreshed on startup)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Workspace Admin
